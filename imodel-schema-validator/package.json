{
  "name": "@bentley/imodel-schema-validator",
  "description": "This tool validates an iModel's Schemas.",
  "main": "./lib/iModelSchemaValidator.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/iTwin/bis-schema-validation"
  },
  "license": "MIT",
  "author": {
    "name": "Bentley Systems, Inc.",
    "url": "http://www.bentley.com"
  },
  "version": "1.0.7",
  "bin": {
    "imodel-schema-validator": "./bin/index.js"
  },
  "scripts": {
    "build": "tsc 1>&2 && npm run copy:test-assets",
    "lint": "eslint -f visualstudio \"./src/**/*.ts\" 1>&2",
    "test": "mocha --timeout=999999999 --check-leaks --global _playwrightInstance",
    "tests:ValidateReleasedBisSchemas": "betools test --grep \"Import latest released version of all schemas in bis-schemas repository into an iModel and perform all validations.\" --timeout=999999999",
    "tests:ValidateWIPBisSchemas": "betools test --grep \"Import WIP version of all schemas from bis-schemas repository into an iModel and perform BIS-rules validation.\" --timeout=999999999",
    "cover": "nyc npm -s test",
    "clean": "rimraf lib",
    "copy:test-assets": "cpx \"./src/test/assets/**/*\" ./lib/test/assets"
  },
  "dependencies": {
    "@itwin/ecschema-locaters": "5.9.3",
    "@itwin/ecschema-metadata": "5.9.3",
    "@itwin/ecschema-editing": "5.9.3",
    "@itwin/oidc-signin-tool": "^5.1.3",
    "@itwin/core-bentley": "5.9.3",
    "@itwin/core-geometry": "5.9.3",
    "@itwin/core-backend": "5.9.3",
    "@itwin/core-quantity": "5.9.3",
    "@itwin/core-common": "5.9.3",
    "@itwin/imodels-access-backend": "6.1.1",
    "@itwin/imodels-access-common": "6.1.1",
    "@itwin/imodels-client-authoring": "6.2.0",
    "@itwin/imodels-client-management": "6.2.0",
    "@bentley/schema-comparer": "1.0.7",
    "@bentley/schema-validator": "1.0.7",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-sha1": "^0.6.0",
    "readdirp": "^5.0.0",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@itwin/eslint-plugin": "^6.1.0",
    "@itwin/build-tools": "5.9.3",
    "@types/node": "~20.17.0",
    "@types/chai": "4.3.1",
    "@types/mocha": "^10.0.6",
    "cpx2": "^8.0.2",
    "typescript": "~5.6.2",
    "chai": "^4.3.10",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "eslint": "^9.39.4"
  }
}
