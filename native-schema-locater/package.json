{
  "name": "@bentley/native-schema-locater",
  "description": "Contains an XML schema file locater which uses the native addon to deserialize EC 3.1 schemas",
  "license": "MIT",
  "version": "1.0.6",
  "main": "./lib/native-schema-locater.js",
  "typings": "./lib/native-schema-locater",
  "repository": {
    "type": "git",
    "url": "https://github.com/iTwin/bis-schema-validation"
  },
  "scripts": {
    "clean": "rimraf lib",
    "lint": "eslint -f visualstudio \"./src/**/*.ts\" 1>&2",
    "beforeBuild": "npm run clean && npm run lint",
    "build": "npm run beforeBuild && tsc && npm run copy:test-assets",
    "test": "mocha",
    "test:watch": "betools test --watch",
    "cover": "nyc npm -s test",
    "copy:test-assets": "cpx \"./src/test/assets/**/*\" ./lib/test/assets"
  },
  "keywords": [
    "Bentley",
    "iModel",
    "iModelJs",
    "EC"
  ],
  "author": {
    "name": "Bentley Systems, Inc.",
    "url": "http://www.bentley.com"
  },
  "devDependencies": {
    "@itwin/eslint-plugin": "^6.1.0",
    "@itwin/build-tools": "5.9.3",
    "@types/chai": "4.3.1",
    "@types/chai-as-promised": "^7",
    "@types/fs-extra": "^5.0.4",
    "@types/mocha": "^10.0.6",
    "@types/node": "~20.17.0",
    "@types/sinon": "^17.0.2",
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "cpx2": "^8.0.0",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "rimraf": "^6.1.3",
    "sinon": "^17.0.2",
    "typescript": "~5.6.2",
    "source-map-support": "^0.5.9",
    "eslint": "^9.39.4"
  },
  "peerDependencies": {
    "@itwin/ecschema-metadata": "5.9.3",
    "@itwin/ecschema-locaters": "5.9.3"
  },
  "dependencies": {
    "@itwin/core-bentley": "5.9.3",
    "@itwin/core-geometry": "5.9.3",
    "@itwin/imodels-access-backend": "6.1.1",
    "@itwin/core-backend": "5.9.3",
    "@itwin/core-quantity": "5.9.3",
    "@itwin/core-common": "5.9.3",
    "@xmldom/xmldom": "~0.8.13",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^7.0.1"
  }
}